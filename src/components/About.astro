---
import '@/styles/animations.css';
---

<section
  id="about"
  class="relative isolate overflow-hidden px-6 py-24 text-[var(--navy-deep)] md:px-10 md:py-28"
>
  <div class="about-wrapper slide-in-left mx-auto max-w-7xl">
    <!-- Text side -->
    <div class="about-text">
      <div class="space-y-8">
        <a
          href="https://www.linkedin.com/in/daoquynh29/"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-block w-full text-center transition-transform duration-200 hover:-translate-y-0.5 focus-visible:-translate-y-0.5"
        >
          <h2
            class="group-hover:text-[var(--navy-deep)]/70 group-focus-visible:text-[var(--navy-deep)]/70 text-center text-2xl font-extrabold uppercase tracking-widest text-[var(--navy-deep)] transition-colors duration-200 sm:text-3xl lg:text-4xl"
          >
            About Me
          </h2>
        </a>

        <div
          class="space-y-4 text-center text-sm leading-relaxed text-[var(--navy-ink)] sm:space-y-6 sm:text-base"
        >
          <p>
            I'm a University of Minnesota grad who began in pre-med before pivoting into tech for
            its nonstop learning and problem-solving. My previous work—spanning healthcare (with
            both animals and people), customer service, tutoring, and research—has given me a broad
            skill set and perspective. As a full-stack developer, I've worked on solo and team
            projects, aiming to leverage technology for positive impact.
          </p>
          <p>
            Outside of coding, I love rock climbing, photography, traveling, and foodie adventures.
            I'm also a longtime volunteer at the Animal Humane Society.
          </p>
        </div>
      </div>
    </div>

    <!-- Image side -->
    <div class="about-image-panel slide-in-right">
      <div
        class="absolute inset-x-0 top-0 h-24 bg-gradient-to-b from-[var(--sky-frost)] to-transparent"
      >
      </div>
      <div class="relative flex h-full flex-col gap-4 rounded-[1.5rem] bg-white p-4 md:p-5">
        <div class="px-2">
          <h3
            class="text-center text-base font-extrabold tracking-tight text-[var(--navy-deep)] sm:text-xl"
          >
            Sr. Fluff
          </h3>
        </div>
        <div
          class="overflow-hidden rounded-[1.4rem] border border-[var(--sky-border)] bg-[var(--sky-wash)]"
        >
          <img
            src="/assets/other/fluff.jpeg"
            alt="A fluffy white bunny sitting in the grass"
            class="h-full min-h-[320px] w-full object-cover object-center lg:min-h-[560px]"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>

  <a
    href="#portfolio"
    class="absolute inset-x-0 bottom-8 flex animate-bounce justify-center text-[#04285f]/60 transition-colors hover:text-[#04285f]"
    aria-label="Next section"
  >
    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"
      ></path>
    </svg>
  </a>
</section>

<style>
  .about-wrapper {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.75);
    border-radius: 36px;
    display: grid;
    grid-template-columns: 1fr;
    overflow: hidden;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 24px 70px rgba(7, 46, 108, 0.16);
  }

  @media (min-width: 1024px) {
    .about-wrapper {
      grid-template-columns: 1fr 1fr;
    }
  }

  .about-text {
    display: flex;
    align-items: center;
    padding: 48px 40px;
  }

  .about-text > div {
    width: 100%;
  }

  @media (min-width: 640px) {
    .about-text {
      padding: 56px 56px;
    }
  }

  @media (min-width: 1024px) {
    .about-text {
      padding: 64px 72px;
    }
  }

  .about-image-panel {
    position: relative;
    overflow: hidden;
    padding: 32px;
    background: rgba(255, 255, 255, 0.55);
    border-top: 1px solid rgba(255, 255, 255, 0.35);
  }

  @media (min-width: 1024px) {
    .about-image-panel {
      border-top: none;
      border-left: 1px solid rgba(255, 255, 255, 0.35);
    }
  }
</style>

<script>
  const els = document.querySelectorAll('.slide-in-left, .slide-in-right');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );
  els.forEach((el) => observer.observe(el));
</script>
