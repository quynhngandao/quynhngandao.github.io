---
import '@/styles/header.css';

const navLinks = [
  { label: 'about me', href: '#about' },
  { label: 'portfolio', href: '#project' },
  { label: 'experience', href: '#experience' },
  { label: 'skills', href: '#skills' },
  { label: 'photography', href: '#photography' },
];
---

<header class="fixed inset-x-0 top-0 z-50">
  <div class="bg-white/5 absolute inset-x-0 top-0 h-full backdrop-blur-md"></div>

  <nav class="relative mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-4">
    <!-- Logo -->
    <a
      href="/"
      class="nav-logo inline-flex items-center gap-2 whitespace-nowrap text-white transition-all duration-200 hover:-translate-y-0.5 hover:opacity-70 focus-visible:-translate-y-0.5"
    >
      Quynh Dao
      <svg
        class="h-[1.5em] w-[1.5em] animate-bounce"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M8 9 4 12l4 3"></path>
        <path d="m16 9 4 3-4 3"></path>
        <path d="m14 4-4 16"></path>
      </svg>
    </a>

    <!-- Desktop nav links -->
    <ul class="hidden items-center gap-8 md:flex">
      {
        navLinks.map(({ label, href }) => (
          <li>
            <a
              href={href}
              data-nav-link
              class="nav-link text-white/60 relative transition-colors hover:text-white"
            >
              {label}
              <span class="nav-underline absolute -bottom-1 left-0 h-px w-full origin-left scale-x-0 bg-white transition-transform duration-200" />
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Desktop contact button -->
    <a
      href="#contact"
      class="nav-contact hidden rounded-full bg-white px-5 py-2 text-navy-cloud transition-transform hover:-translate-y-0.5 md:inline-flex"
    >
      contact me
    </a>

    <!-- Mobile hamburger -->
    <button
      id="menu-btn"
      class="text-white/70 flex cursor-pointer flex-col gap-1.5 hover:text-white md:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="hamburger-bar block h-px w-5 bg-current transition-all duration-300"></span>
      <span class="hamburger-bar block h-px w-5 bg-current transition-all duration-300"></span>
      <span class="hamburger-bar block h-px w-5 bg-current transition-all duration-300"></span>
    </button>
  </nav>

  <!-- Mobile dropdown -->
  <div
    id="mobile-menu"
    class="bg-navy/95 hidden flex-col gap-4 px-[6vw] py-6 backdrop-blur-md md:hidden"
  >
    {
      navLinks.map(({ label, href }) => (
        <a href={href} class="nav-link text-white/80 transition-colors hover:text-white">
          {label}
        </a>
      ))
    }
    <a
      href="#contact"
      class="nav-contact mt-2 inline-flex w-fit rounded-full bg-white px-5 py-2 text-navy-cloud transition-transform hover:-translate-y-0.5"
    >
      contact me
    </a>
  </div>
</header>


<script>
  // Mobile menu toggle
  const btn = document.getElementById('menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;

  btn.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!open));
    menu.classList.toggle('hidden');
    menu.classList.toggle('flex');
  });

  // Close mobile menu when a link is clicked
  menu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      btn.setAttribute('aria-expanded', 'false');
      menu.classList.add('hidden');
      menu.classList.remove('flex');
    });
  });

  // Active nav link via IntersectionObserver
  const sections = document.querySelectorAll<HTMLElement>('section[id]');
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navLinks.forEach((link) => {
            const active = link.getAttribute('href') === `#${entry.target.id}`;
            link.classList.toggle('active', active);
          });
        }
      });
    },
    { rootMargin: '-40% 0px -55% 0px' }
  );

  sections.forEach((s) => observer.observe(s));
</script>
