---
import Footer from '@/components/Footer.astro';

const emailAddress = 'quynhngandao@outlook.com';
---

<section id="contact" class="relative px-4 py-12 pb-16 sm:px-6 md:py-24 md:pb-20">
  <div
    class="border-white/15 bg-white/10 relative z-10 mx-auto grid max-w-5xl gap-6 rounded-[1.25rem] border p-5 shadow-[0_24px_80px_rgba(4,40,95,0.18)] backdrop-blur-sm sm:gap-8 sm:rounded-[1.75rem] sm:p-8 md:grid-cols-[0.9fr_1.1fr] md:rounded-[2rem] md:p-10"
  >
    <div class="space-y-5">
      <h2
        class="text-2xl font-extrabold uppercase tracking-widest text-white sm:text-3xl lg:text-4xl"
      >
        Let's Connect
      </h2>
      <p class="text-white/70 max-w-md text-sm leading-relaxed sm:text-base">
        Have an idea, a question, or just want to say hi? Drop me a message, and I’ll get back to
        you soon.
      </p>
    </div>

    <form id="mailing-form" class="border-white/10 bg-navy-cloud/20 space-y-4 rounded-[1.5rem]">
      <div>
        <label for="contact-name" class="text-white/80 mb-2 block text-sm font-medium">Name</label>
        <input
          id="contact-name"
          name="name"
          type="text"
          placeholder="Your name"
          class="border-white/15 bg-white/10 placeholder:text-white/30 focus:border-white/35 focus:bg-white/15 w-full rounded-2xl border px-3 py-2 text-sm text-navy-cloud outline-none transition placeholder:italic sm:px-4 sm:py-3 sm:text-base"
        />
      </div>

      <div>
        <label for="contact-email" class="text-white/80 mb-2 block text-sm font-medium">Email</label
        >
        <input
          id="contact-email"
          name="email"
          type="email"
          placeholder="you@example.com"
          required
          class="border-white/15 bg-white/10 placeholder:text-white/30 focus:border-white/35 focus:bg-white/15 w-full rounded-2xl border px-3 py-2 text-sm text-navy-cloud outline-none transition placeholder:italic sm:px-4 sm:py-3 sm:text-base"
        />
      </div>

      <div>
        <label for="contact-message" class="text-white/80 mb-2 block text-sm font-medium"
          >Message</label
        >
        <textarea
          id="contact-message"
          name="message"
          rows="4"
          placeholder="Tell me about your idea, timeline, or just say hi."
          required
          class="border-white/15 bg-white/10 placeholder:text-white/30 focus:border-white/35 focus:bg-white/15 w-full rounded-2xl border px-3 py-2 text-sm text-navy-cloud outline-none transition placeholder:italic sm:px-4 sm:py-3 sm:text-base"
        ></textarea>
      </div>

      <a
        href={`mailto:${emailAddress}`}
        class="inline-flex w-fit items-center gap-2 rounded-full bg-white px-4 py-2 text-xs font-semibold text-navy-cloud transition-transform hover:-translate-y-0.5 sm:px-6 sm:py-3 sm:text-sm"
      >
        Send Message
      </a>
    </form>
  </div>

  <a
    href="#"
    class="absolute inset-x-0 bottom-8 z-20 flex animate-bounce justify-center text-[#04285f]/60 transition-colors hover:text-[#04285f]"
    aria-label="Back to top"
  >
    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"
      ></path>
    </svg>
  </a>
</section>

<script define:vars={{ emailAddress }}>
  const form = document.getElementById('mailing-form');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const formData = new FormData(form);
    const name = String(formData.get('name') ?? '').trim();
    const email = String(formData.get('email') ?? '').trim();
    const subject = String(formData.get('subject') ?? '').trim() || 'Portfolio inquiry';
    const message = String(formData.get('message') ?? '').trim();

    const body = [name ? `Name: ${name}` : null, email ? `Email: ${email}` : null, '', message]
      .filter(Boolean)
      .join('\n');

    window.location.href = `mailto:${emailAddress}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  });
</script>

<Footer />
