<section id="skills" class="relative px-4 py-20 pb-24 md:px-8 md:py-28">
  <div class="mx-auto w-full space-y-8">
    <!-- Filter buttons -->
    <div class="flex flex-wrap justify-center gap-3">
      {
        categories.map((cat, i) => (
          <button
            class:list={['skills-filter-btn', i === 0 && 'active']}
            data-filter={cat.toLowerCase()}
          >
            {cat}
          </button>
        ))
      }
    </div>

    <!-- Tech card grid -->
    <div class="flex w-full flex-wrap justify-center gap-5 md:gap-6">
      {
        techStack.map((tech) => (
          <div
            class="tech-card group flex w-[calc(50%-10px)] flex-col items-center rounded-2xl p-4 text-center sm:w-[calc(33.333%-14px)] sm:p-6 md:w-[calc(33.333%-16px)] md:p-8 lg:w-[calc(25%-18px)] xl:w-[calc(20%-20px)]"
            data-category={tech.category.toLowerCase()}
          >
            <img
              src={tech.icon}
              alt={tech.title}
              width="80"
              height="80"
              class="mb-3 h-12 w-12 object-contain transition-transform duration-300 group-hover:scale-110 sm:h-16 sm:w-16 md:h-20 md:w-20"
              loading="lazy"
            />
            <h3 class="mb-1 text-xs font-bold leading-tight sm:text-base" style="color: #04285f">
              {tech.title}
            </h3>
            <p class="text-xs sm:text-sm" style="color: #245f9c; opacity: 0.7">
              {tech.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Scroll cue -->
  <a
    href="#experience"
    class="absolute inset-x-0 bottom-8 flex animate-bounce justify-center text-[#04285f]/60 transition-colors hover:text-[#04285f]"
    aria-label="Next section"
  >
    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"
      ></path>
    </svg>
  </a>
</section>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.skills-filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.tech-card');
  const DURATION = 350;

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'all';
      buttons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      const toShow: HTMLElement[] = [];
      const toHide: HTMLElement[] = [];

      cards.forEach((card) => {
        const cat = card.dataset.category ?? '';
        const shouldShow = filter === 'all' || cat === filter;
        const isHidden = card.classList.contains('hidden');
        if (shouldShow && isHidden) toShow.push(card);
        else if (!shouldShow && !isHidden) toHide.push(card);
      });

      // Phase 1: animate out
      toHide.forEach((card) => {
        card.classList.add('is-hiding');
        setTimeout(() => {
          card.classList.add('hidden');
          card.classList.remove('is-hiding');
        }, DURATION);
      });

      // Phase 2: animate in after exits finish
      toShow.forEach((card) => {
        setTimeout(
          () => {
            card.classList.add('is-entering');
            card.classList.remove('hidden');
            requestAnimationFrame(() => {
              requestAnimationFrame(() => {
                card.classList.remove('is-entering');
              });
            });
          },
          toHide.length ? DURATION : 0
        );
      });
    });
  });
</script>
