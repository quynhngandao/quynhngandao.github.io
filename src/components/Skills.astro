---
interface TechItem {
  id: number;
  title: string;
  category: 'Frontend' | 'Backend' | 'Testing' | 'Design' | 'Analytics' | 'Other';
  icon: string;
  description: string;
}

const categories = ['All', 'Frontend', 'Backend', 'Testing', 'Design', 'Analytics', 'Other'];

const techStack: TechItem[] = [
  { id: 1,  title: 'JavaScript',   category: 'Frontend',  icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/javascript/javascript-original.svg',         description: 'Programming Language' },
  { id: 2,  title: 'HTML/CSS',     category: 'Frontend',  icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/html5/html5-original.svg',                   description: 'Web Markup & Styling' },
  { id: 3,  title: 'TypeScript',   category: 'Frontend',  icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/typescript/typescript-original.svg',         description: 'Typed JavaScript superset' },
  { id: 4,  title: 'React',        category: 'Frontend',  icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/react/react-original.svg',                   description: 'JavaScript Library' },
  { id: 5,  title: 'Next.js',      category: 'Frontend',  icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nextjs/nextjs-original.svg',                 description: 'React Framework' },
  { id: 6,  title: 'React Native', category: 'Frontend',  icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/react/react-original.svg',                   description: 'Mobile Development' },
  { id: 7,  title: 'Angular',      category: 'Frontend',  icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/angularjs/angularjs-original.svg',           description: 'Web Framework' },
  { id: 8,  title: 'Tailwind CSS', category: 'Frontend',  icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/tailwindcss/tailwindcss-original.svg',       description: 'CSS Framework' },
  { id: 9,  title: 'Material UI',  category: 'Frontend',  icon: 'https://v4.mui.com/static/logo.png',                                                                   description: 'React Component Library' },
  { id: 10, title: 'Node.js',      category: 'Backend',   icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nodejs/nodejs-original.svg',                 description: 'JavaScript Runtime' },
  { id: 11, title: 'PostgreSQL',   category: 'Backend',   icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/postgresql/postgresql-original.svg',         description: 'SQL Database' },
  { id: 12, title: 'GraphQL',      category: 'Backend',   icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/graphql/graphql-plain.svg',                  description: 'API Query Language' },
  { id: 13, title: 'Jest',         category: 'Testing',   icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/jest/jest-plain.svg',                        description: 'Testing Framework' },
  { id: 14, title: 'Cypress',      category: 'Testing',   icon: 'https://www.chromatic.com/integrations/cypress.svg',                                                   description: 'E2E Testing' },
  { id: 15, title: 'Storybook',    category: 'Testing',   icon: 'https://avatars.githubusercontent.com/u/22632046?s=200&v=4',                                           description: 'UI Component Workshop' },
  { id: 16, title: 'Chromatic',    category: 'Testing',   icon: 'https://static.intercomassets.com/avatars/1502568/square_128/custom_avatar-1567713303.png',             description: 'Visual Testing' },
  { id: 17, title: 'Figma',        category: 'Design',    icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/figma/figma-original.svg',                   description: 'UI/UX Design' },
  { id: 18, title: 'Lightroom',    category: 'Design',    icon: 'https://upload.wikimedia.org/wikipedia/commons/b/b6/Adobe_Photoshop_Lightroom_CC_logo.svg',            description: 'Photo Editing' },
  { id: 19, title: 'Canva',        category: 'Design',    icon: 'https://cdn-1.webcatalog.io/catalog/canva-cn/canva-cn-icon.png?v=1754269934555',                        description: 'Graphic Design' },
  { id: 20, title: 'Piano',        category: 'Analytics', icon: 'https://media.licdn.com/dms/image/v2/D4E0BAQGNtMCt9RKDDg/company-logo_200_200/B4EZq7Ra4mJ0AI-/0/1764078497760/piano_io_logo?e=2147483647&v=beta&t=30JBaz9e4mTskAX7n_2fT1g8qWlc2idebUnhEy7NY0w', description: 'Data Analytics Platform' },
  { id: 21, title: 'Optimizely',   category: 'Analytics', icon: 'https://app.optimizely.com/static/img/rebrand/rebrand-logo.svg',                                       description: 'Experimentation Platform' },
  { id: 22, title: 'Git',          category: 'Other',     icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/git/git-original.svg',                       description: 'Version Control' },
  { id: 23, title: 'Vercel',       category: 'Other',     icon: 'https://assets.vercel.com/image/upload/front/favicon/vercel/180x180.png',                              description: 'Cloud Platform' },
  { id: 24, title: 'AWS',          category: 'Other',     icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/amazonwebservices/amazonwebservices-original-wordmark.svg', description: 'Cloud Platform' },
];
---

<section
  id="skills"
  class="sky-section-gradient relative flex min-h-screen flex-col items-center justify-center py-24 px-4"
>
  <h2 class="mb-10 text-center text-2xl font-bold uppercase tracking-widest text-white drop-shadow">
    Skills
  </h2>

  <!-- Filter buttons -->
  <div class="mb-10 flex flex-wrap justify-center gap-3">
    {categories.map((cat, i) => (
      <button
        class={`skills-filter-btn${i === 0 ? ' active' : ''}`}
        data-filter={cat.toLowerCase()}
      >
        {cat}
      </button>
    ))}
  </div>

  <!-- Tech card grid -->
  <div class="mx-auto w-full max-w-6xl grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
    {techStack.map((tech) => (
      <div
        class="tech-card bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow duration-200 p-6 flex flex-col items-center text-center"
        data-category={tech.category.toLowerCase()}
      >
        <img
          src={tech.icon}
          alt={tech.title}
          width="64"
          height="64"
          class="mb-4 h-16 w-16 object-contain"
          loading="lazy"
        />
        <h3 class="mb-1 text-sm font-bold leading-tight" style="color: #245f9c">{tech.title}</h3>
        <p class="text-xs" style="color: #9e9d9c">{tech.description}</p>
      </div>
    ))}
  </div>

  <!-- Scroll cue -->
  <a
    href="#photography"
    class="absolute inset-x-0 bottom-8 flex animate-bounce justify-center text-white/50 transition-colors hover:text-white/80"
    aria-label="Next section"
  >
    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </a>
</section>

<style is:global>
  .skills-filter-btn {
    padding: 0.375rem 1.25rem;
    border-radius: 9999px;
    border: 1px solid rgba(36, 95, 156, 0.25);
    background: white;
    color: #245f9c;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 150ms ease, color 150ms ease, border-color 150ms ease;
    font-family: 'Sora', system-ui, sans-serif;
  }
  .skills-filter-btn.active {
    background: #245f9c;
    color: white;
    border-color: #245f9c;
  }
  .skills-filter-btn:not(.active):hover {
    background: rgba(255, 255, 255, 0.85);
  }
  .tech-card.hidden {
    display: none;
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.skills-filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.tech-card');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'all';

      buttons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      cards.forEach((card) => {
        const cat = card.dataset.category ?? '';
        if (filter === 'all' || cat === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>
