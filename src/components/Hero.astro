    class="hero-background"
    viewBox="0 0 1440 900"
    preserveAspectRatio="xMidYMid slice"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <!-- TOP-LEFT cloud cluster -->
    <path
      d="M 0,0 L 610,0 C 648,0 668,38 656,96 C 644,154 612,194 580,244 C 548,294 526,330 504,370 Q 478,412 444,438 Q 400,468 355,488 Q 298,510 238,520 C 164,532 84,522 36,494 C 6,476 -4,444 0,410 Z"
      fill="#04285F"></path>
