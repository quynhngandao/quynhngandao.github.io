      d="M 1440,0 L 898,0 C 868,0 852,34 863,88 C 874,142 904,180 934,226 C 964,272 985,306 1006,343 Q 1030,382 1062,407 Q 1103,434 1145,452 Q 1197,473 1250,482 C 1314,493 1380,483 1420,458 C 1444,442 1440,412 1440,378 Z"
      fill="#2F95EE"></path>
    <path
      d="M 1440,0 L 982,0 C 960,0 948,28 958,72 C 968,116 994,150 1022,188 C 1050,226 1070,256 1090,288 Q 1112,322 1140,342 Q 1176,366 1216,378 C 1262,392 1314,390 1352,372 C 1390,354 1430,322 1440,290 Z"
      fill="#87C2F4"
      opacity="0.6"></path>

    <!-- BOTTOM-LEFT cloud -->
    <path
      d="M 0,900 L 0,668 C 40,630 96,610 165,617 C 234,624 282,664 292,728 C 302,792 264,848 192,876 C 140,896 68,904 0,900 Z"
      fill="#04285F"></path>
    <path
      d="M 0,900 L 0,696 C 32,662 80,644 140,650 C 200,656 240,690 248,746 C 256,802 224,846 162,870 C 116,888 56,898 0,900 Z"
      fill="#2F95EE"></path>

    <!-- BOTTOM-RIGHT cloud -->
    <path
      d="M 1440,900 L 1440,668 C 1400,630 1344,610 1275,617 C 1206,624 1158,664 1148,728 C 1138,792 1176,848 1248,876 C 1300,896 1372,904 1440,900 Z"
      fill="#04285F"></path>
    <path
      d="M 1440,900 L 1440,696 C 1408,662 1360,644 1300,650 C 1240,656 1200,690 1192,746 C 1184,802 1216,846 1278,870 C 1324,888 1384,898 1440,900 Z"
      fill="#2F95EE"></path>

    <!-- Floating cream bubbles removed -->
  </svg>

  <!-- ── Giant name — lowest layer ─────────────────────────────── -->
  <h1 class="hero-bg-name hero-bg-name-desktop hero-bg-name-mobile">QUYNH</h1>

  <!-- ── Character illustration ────────────────────────────────── -->
  <img src="/assets/me.png" alt="" aria-hidden="true" class="hero-character" />

  <!-- ── Top-left greeting ──────────────────────────────────────── -->
  <div class="hero-greeting hero-greeting-desktop">
    <p class="hero-greeting-text hero-greeting-text-desktop">Hi, I'm</p>
  </div>
  <div class="hero-greeting hero-greeting-mobile">
    <p class="hero-greeting-text hero-greeting-text-mobile">Hi, I'm</p>
  </div>

  <!-- ── Bottom-right role ──────────────────────────────────────── -->
  <div class="hero-role-wrap hero-role-wrap-desktop">
    <p class="hero-role hero-role-text-desktop">Software Engineer</p>
  </div>

  <div class="hero-role-wrap hero-role-wrap-mobile">
    <p class="hero-role hero-role-text-mobile">Software Engineer</p>
  </div>

  <!-- ── Scroll cue ─────────────────────────────────────────────── -->
  <a href="#about" class="hero-scroll-cue animate-bounce" aria-label="Scroll down">
    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"
      ></path>
    </svg>
  </a>
</section>
